---
# .yamllint — YAML linting configuration
extends: default

rules:
  line-length:
    max: 160
    level: warning
  document-start: disable
  truthy: disable
  braces:
    max-spaces-inside: 1
  comments:
    min-spaces-from-content: 1
  indentation:
    spaces: 2
    indent-sequences: consistent
