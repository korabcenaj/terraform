# EXAMPLE secrets file — copy to secrets.auto.tfvars and fill in real values
# secrets.auto.tfvars is gitignored

pihole_web_password    = "CHANGE_ME"
grafana_admin_password = "CHANGE_ME_GRAFANA"
minio_root_password    = "CHANGE_ME_MINIO_PASSWORD"
vault_token            = "CHANGE_ME_VAULT_TOKEN"
argocd_admin_password_bcrypt = ""

# OAuth2 Proxy — get client_id/secret from your GitHub OAuth App settings
# Generate cookie_secret with: openssl rand -base64 32 | tr -- '+/' '-_' | tr -d '='
oauth2_proxy_client_id     = "CHANGE_ME_CLIENT_ID"
oauth2_proxy_client_secret = "CHANGE_ME_CLIENT_SECRET"
oauth2_proxy_cookie_secret = "CHANGE_ME_COOKIE_SECRET"

# Local Keycloak IdP
keycloak_admin_password      = "CHANGE_ME_KEYCLOAK_ADMIN_PASSWORD"
keycloak_postgresql_password = "CHANGE_ME_KEYCLOAK_DB_PASSWORD"

# Native OIDC clients for verified apps
argocd_oidc_client_secret  = "CHANGE_ME_ARGOCD_OIDC_SECRET"
grafana_oidc_client_secret = "CHANGE_ME_GRAFANA_OIDC_SECRET"
