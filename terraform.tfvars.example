# Docker-Apps Terraform Configuration
# Copy this file to terraform.tfvars and customize the values

# Cluster configuration
cluster_name    = "home-lab"
environment     = "production"
kubeconfig_path = "~/.kube/config"

# Enable/disable modules
enable_portfolio           = true
enable_jellyfin            = false
enable_qbittorrent         = false
enable_pihole              = true
enable_matrix_synapse      = false
enable_monitoring          = true
enable_network_policies    = true
enable_pod_security_standards = true
enable_resource_quotas     = true
enable_pod_disruption_budgets = true

# ingress-nginx hardening defaults (set >0 to enable global limits)
ingress_nginx_limit_rps         = 10
ingress_nginx_limit_connections = 20
ingress_nginx_enable_modsecurity = false
ingress_nginx_enable_owasp_crs   = false

# Pi-hole configuration
pihole_web_password = "changeme"  # Change this to a secure password!
pihole_load_balancer_ip = "192.168.1.210"

# CoreDNS forwarding for private domain resolution from inside the cluster.
# Set to your Pi-hole/router DNS IP.
private_dns_ip = "192.168.1.210"

# Application configurations
portfolio_replicas   = 1
jellyfin_replicas    = 1
qbittorrent_replicas = 1
# Matrix Synapse defaults to https://chat.<ingress_base_domain> when enabled.
# matrix_synapse_server_name                  = "chat.local.lan"
# matrix_synapse_public_base_url              = "https://chat.local.lan"
# matrix_synapse_storage_size                 = "20Gi"
# matrix_synapse_registration_shared_secret   = "REPLACE_WITH_32_PLUS_CHAR_SECRET"
# matrix_synapse_bootstrap_admin_enabled      = true
# matrix_synapse_bootstrap_admin_username     = "admin"
# matrix_synapse_bootstrap_admin_password     = "REPLACE_WITH_STRONG_PASSWORD"
# matrix_synapse_oidc_enabled                 = true
# matrix_synapse_oidc_client_id               = "matrix-synapse"
# matrix_synapse_oidc_client_secret           = "REPLACE_WITH_KEYCLOAK_CLIENT_SECRET"
# matrix_synapse_federation_enabled           = false
# matrix_synapse_well_known_enabled           = true
# Cloudflare Tunnel (for CGNAT/no port-forward setups)
# enable_cloudflare_tunnel                    = true
# cloudflare_tunnel_token                     = "REPLACE_WITH_CLOUDFLARE_TUNNEL_TOKEN"
# qbittorrent_node_name = "k8s"
# qbittorrent_storage_class = "local-path"

# Storage configuration
jellyfin_storage_class = "local-path"
jellyfin_config_size   = "20Gi"
jellyfin_cache_size    = "5Gi"

# Resource defaults (for standard services)
default_cpu_request    = "100m"
default_memory_request = "128Mi"
default_cpu_limit      = "250m"
default_memory_limit   = "256Mi"

# Tags applied to all resources
tags = {
  managed-by  = "terraform"
  environment = "production"
  cluster     = "home-lab"
}
